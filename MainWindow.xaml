<Window x:Class="wpf_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:wpf_projekt.Views"
        xmlns:vm="clr-namespace:wpf_projekt.ViewModels"
        Title="Zarządzanie Finansami" Height="700" Width="950"
        Background="{StaticResource BackgroundBrush}" 
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pasek górny: użytkownik + wylogowanie -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="Wyloguj"
                    Style="{StaticResource SecondaryBtn}"
                    DockPanel.Dock="Right"
                    Width="100"
                    Click="LogoutButton_Click"/>
            <TextBlock x:Name="UserNameBlock"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{StaticResource MutedBrush}"/>
        </DockPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Stylizowanie zakładek -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ══════ DODAJ ══════ -->
            <TabItem Header="Nowa operacja">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>

                        <!-- KARTA 1: DODAJ TRANSAKCJĘ -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Nowa transakcja" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lewa Kolumna -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Kwota (zł)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="AmountTextBox" Margin="0,0,0,15"
                                        Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                          PreviewTextInput="AmountTextBox_PreviewTextInput"/>
                                        <TextBlock Text="Data transakcji" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker Margin="0,0,0,15" SelectedDate="{Binding TransactionDate}"/>
                                    </StackPanel>

                                    <!-- Prawa Kolumna -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Kategoria" Style="{StaticResource FieldLabel}"/>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding Categories}"
                                                      SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"/>
                                            <Button Grid.Column="1" Content="+" Width="32" Margin="10,0,0,0"
                                                    Style="{StaticResource SecondaryBtn}" ToolTip="Dodaj własną kategorię"
                                                    Command="{Binding OpenAddCategoryCommand}"/>
                                        </Grid>

                                        <TextBlock Text="Typ transakcji" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15" Height="32">
                                            <RadioButton Content="Wydatek" IsChecked="{Binding IsExpense}" 
                                                         Margin="0,0,20,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}"/>
                                            <RadioButton Content="Przychód" IsChecked="{Binding IsIncome}" 
                                                         VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                        </StackPanel>

                                        <TextBlock Text="Opis" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Margin="0,0,0,15" Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

<!-- Przycisk zapisu pod kolumnami -->
                                <Button Content="Dodaj transakcję" Command="{Binding SaveTransactionCommand}"
                                        Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Right" Width="180" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

 <!-- KARTA 2: TRANSFER -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Transfer między kontami" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,15,10" Width="180">
                                        <TextBlock Text="Na konto" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding TransferTo}" DisplayMemberPath="DisplayName"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,15,10" Width="120">
                                        <TextBlock Text="Kwota (zł)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding TransferAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,15,10" Width="200">
                                        <TextBlock Text="Opis transferu" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding TransferDescription, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WrapPanel>

                                <Button Content="Wykonaj transfer" Command="{Binding ExecuteTransferCommand}"
                                        Style="{StaticResource SecondaryBtn}" HorizontalAlignment="Right" Width="180" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════ KONTA ══════ -->
            <TabItem Header="Konta">
                <ScrollViewer Margin="0,10,0,0">
                    <StackPanel>

<!--Lista kont-->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Twoje konta" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                                <TextBlock Text="Kliknij 'Wybierz' lub kliknij dwukrotnie, aby ustawić konto jako aktywne."
                                           Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,12"/>

                                <ListBox ItemsSource="{Binding Accounts}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="14,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F5F7FA"/>
                                                        <Setter Property="BorderBrush" Value="#DADDE3"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#EAF4FB"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Ikona aktywności -->
                                                    <TextBlock Grid.Column="0" Text="✔" FontSize="16"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,10,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Dane konta -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock VerticalAlignment="Center" FontSize="14">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                                            <Run Text=" (" Foreground="{StaticResource MutedBrush}"/>
                                                            <Run Text="{Binding KindLabel, Mode=OneWay}" Foreground="{StaticResource MutedBrush}"/>
                                                            <Run Text=")" Foreground="{StaticResource MutedBrush}"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="13" Margin="0,2,0,0">
                                                            <Run Text="Saldo: "/>
                                                            <Run Text="{Binding Balance, StringFormat={}{0:F2} zł, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Typ (chip) -->
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                                            Background="#DDE6F0" Margin="10,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="11"
                                                                   Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- Przycisk Wybierz -->
                                                    <Button Grid.Column="3"
                                                            Content="Wybierz"
                                                            Width="90"
                                                            Command="{Binding DataContext.SelectAccountCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.45"/>
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Brak kont. Dodaj pierwsze konto poniżej."
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Accounts.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Formularz dodawania konta -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Dodaj nowe konto" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Nazwa konta" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding NewAccountName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,15,0" Width="150">
                                        <TextBlock Text="Typ" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox SelectedValue="{Binding NewAccountType}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Osobiste" IsSelected="True"/>
                                            <ComboBoxItem Content="Wspólne"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Margin="0,80,15,0"
                                                Width="150">
                                        <TextBlock Text="Drugi użytkownik"
                                                   Style="{StaticResource FieldLabel}" />
                                        <ComboBox
                                            ItemsSource="{Binding Users}"
                                            SelectedItem="{Binding SelectedSecondUser}"
                                            DisplayMemberPath="Email"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <Button Content="Dodaj konto" Command="{Binding AddAccountCommand}"
                                                Style="{StaticResource PrimaryBtn}" Width="140"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════ TRANSAKCJE ══════ -->
            <TabItem Header="Transakcje">
                <views:TransactionsView DataContext="{Binding TransactionsVm}" Margin="0,10,0,0"/>
            </TabItem>

            <!-- ══════ PODSUMOWANIE ══════ -->
            <TabItem Header="Podsumowanie">
                <views:SummaryView DataContext="{Binding SummaryVm}" Margin="0,10,0,0"/>
            </TabItem>
            <!-- Logi -->
            <TabItem Header="Historia zdarzeń">
                <Grid Background="White">
                    <views:EventLogsView Margin="10"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>