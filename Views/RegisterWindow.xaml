<Window x:Class="wpf_projekt.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:wpf_projekt.Converters"
        Title="Finance Manager – Rejestracja" Height="550" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <conv:BoolNegationConverter x:Key="BoolNeg"/>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}" Margin="30">
        <StackPanel>

            <TextBlock Text="Finance Manager"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock Text="Utwórz nowe konto"
                       FontSize="13" Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Imię i nazwisko -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="IMIĘ" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="NAZWISKO" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!-- E-mail -->
            <TextBlock Text="E-MAIL" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14"/>

            <!-- Hasło -->
            <TextBlock Text="HASŁO" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PasswordInput" Height="32"
                         Padding="8,0" Margin="0,0,0,14"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

            <!-- Powtórz hasło -->
            <TextBlock Text="POWTÓRZ HASŁO" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="ConfirmPasswordInput" Height="32"
                         Padding="8,0" Margin="0,0,0,6"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

            <!-- Komunikat błędu -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Margin="0,0,0,14"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Przyciski -->
            <Button x:Name="RegisterButton"
                    Content="Utwórz konto"
                    Style="{StaticResource PrimaryBtn}"
                    Click="RegisterButton_Click"
                    IsDefault="True"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolNeg}}"
                    Margin="0,0,0,8"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0">
                <Hyperlink Click="BackToLogin_Click"
                           Foreground="{StaticResource AccentBrush}"
                           TextDecorations="Underline">
                    Mam już konto — zaloguj się
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Border>
</Window>
