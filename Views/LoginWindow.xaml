<Window x:Class="wpf_projekt.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:wpf_projekt.Converters"
        Title="Finance Manager – Logowanie" Height="450" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <conv:BoolNegationConverter x:Key="BoolNeg"/>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}" Margin="30">
        <StackPanel>

            <TextBlock Text="Finance Manager"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock Text="Zaloguj się do swojego konta"
                       FontSize="13" Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- E-mail -->
            <TextBlock Text="E-MAIL" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14"/>

            <!-- Hasło -->
            <TextBlock Text="HASŁO" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PasswordInput" Height="32"
                         Padding="8,0" Margin="0,0,0,6"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

            <!-- Komunikat błędu (zwinięty gdy pusty) -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Margin="0,0,0,14"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Przyciski -->
            <Button x:Name="LoginButton"
                    Content="Zaloguj"
                    Style="{StaticResource PrimaryBtn}"
                    Click="LoginButton_Click"
                    IsDefault="True"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolNeg}}"
                    Margin="0,0,0,8"/>

            <Button Content="Nie masz konta? Zarejestruj się"
                    Style="{StaticResource SecondaryBtn}"
                    Click="RegisterButton_Click"/>

        </StackPanel>
    </Border>
</Window>
