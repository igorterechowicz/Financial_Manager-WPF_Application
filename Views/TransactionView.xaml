<UserControl x:Class="wpf_projekt.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filtry i przyciski -->
            <RowDefinition Height="*"/>
            <!-- Tabela DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Statystyki na dole -->
        </Grid.RowDefinitions>

        <!-- 1. SEKCOJA FILTRÓW I PRZYCISKÓW -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Rok" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Width="100" Height="28"
                          ItemsSource="{Binding AvailableYears}"
                          SelectedItem="{Binding SelectedYear}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Miesiąc" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Width="100" Height="28"
                          ItemsSource="{Binding AvailableMonths}"
                          SelectedItem="{Binding SelectedMonth}"
                          DisplayMemberPath="Label"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Kategoria" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Width="110" Height="28"
                          ItemsSource="{Binding AvailableCategories}"
                          SelectedItem="{Binding SelectedCategory}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Rodzaj" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Width="100" Height="28"
                          SelectedItem="{Binding SelectedType}">
                    <ComboBox.Items>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Wszystkie</system:String>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Wydatek</system:String>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Przychód</system:String>
                    </ComboBox.Items>
                </ComboBox>
            </StackPanel>

            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Data" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Width="130" Height="28"
                          SelectedItem="{Binding SelectedSort}">
                    <ComboBox.Items>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Od najnowszej</system:String>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Od najstarszej</system:String>
                    </ComboBox.Items>
                </ComboBox>
            </StackPanel>

            <!-- Przyciski eksportu i importu -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                <Button Content="Eksportuj CSV"
                        Width="110" Height="28" Margin="0,0,8,0"
                        Command="{Binding ExportToCsvCommand}"
                        ToolTip="Zapisz widoczne dane do pliku Excel/CSV"
                        Cursor="Hand"/>

                <Button Content="Importuj z CSV" 
                        Command="{Binding ImportCsvCommand}"
                        Width="110" Height="28" 
                        ToolTip="Wczytaj transakcje z pliku CSV" 
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <!-- 2. NOWOCZESNA, CZYTELNA TABELA DATAGRID -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding FilteredTransactions}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  VerticalScrollBarVisibility="Auto"
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  RowBackground="White" AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E5E5"
                  RowHeight="32">

            <!-- STYL NAGŁÓWKÓW: Dodaje rączkę, podświetlenie przy najechaniu i dymek z informacją -->
            <!-- STYL NAGŁÓWKÓW: Dodaje BasedOn (przywraca strzałkę sortowania), rączkę i podświetlenie -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="Background" Value="#EAEAEA" />
                    <Setter Property="Foreground" Value="#333333" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="BorderThickness" Value="0,0,1,2" />
                    <Setter Property="BorderBrush" Value="#CCCCCC" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="ToolTip" Value="Kliknij nagłówek, aby posortować kolumnę" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DCDCDC" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Data"
                                    Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                    Width="110"/>

                <DataGridTextColumn Header="Kategoria"
                                    Binding="{Binding TransactionType.Name}"
                                    Width="140"/>

                <!-- KOLOROWANIE, WYRÓWNANIE I FORMATOWANIE KWOTY -->
                <DataGridTextColumn Header="Kwota"
                                    Binding="{Binding Amount, StringFormat={}{0:F2} zł}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,0,15,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPositive}" Value="True">
                                    <Setter Property="Foreground" Value="Green"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Typ"
                                    Binding="{Binding TypeName}"
                                    Width="90"/>

                <DataGridTextColumn Header="Opis"
                                    Binding="{Binding Description}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0,0,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 3. SEKCOJA STATYSTYK (DYNAMICZNE PODSUMOWANIE NA DOLE) -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Podsumowanie aktualnego widoku:" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="#333333"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,25,0" VerticalAlignment="Center">
                    <TextBlock Text="Przychody: " Foreground="#555555"/>
                    <TextBlock Text="{Binding TotalIncome, StringFormat={}{0:F2} zł}" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,25,0" VerticalAlignment="Center">
                    <TextBlock Text="Wydatki: " Foreground="#555555"/>
                    <TextBlock Text="{Binding TotalExpense, StringFormat={}{0:F2} zł}" FontWeight="Bold" Foreground="Red"/>
                </StackPanel>

                <Border Grid.Column="3" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0" Padding="15,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Saldo końcowe: " FontWeight="Bold" Foreground="#333333"/>
                        <TextBlock Text="{Binding Balance, StringFormat={}{0:F2} zł}" FontWeight="Bold" FontSize="14" Foreground="#222222"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>