<Window x:Class="wpf_projekt.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj nową kategorię" Height="200" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Style="{StaticResource CardStyle}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="51"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Nazwa nowej kategorii" 
                       Grid.Row="0" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>

            <TextBox x:Name="CategoryNameTextBox"
                     Grid.Row="1" VerticalAlignment="Center"
                     Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" Height="30"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0" Width="130">
                <Button Content="Anuluj" Style="{StaticResource SecondaryBtn}" 
                        Margin="0,0,10,0" Command="{Binding CancelCommand}" Width="60"/>
                <Button Content="Zapisz" Style="{StaticResource PrimaryBtn}" 
                        IsDefault="True" Command="{Binding SaveCommand}" Width="60"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>